import pandas as pd
import numpy as np
import xgboost as xgb
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import LabelEncoder
from sklearn.metrics import classification_report, precision_recall_curve, f1_score

# Load Data
train_df = pd.read_csv('data/train_transactions.csv')
test_df = pd.read_csv('data/test_transactions.csv')

def engineer_features(df):
    df = df.copy()
    # Behavior Ratios from Problem Statement
    df['amt_to_limit'] = df['transaction_amount_inr'] / (df['credit_limit_inr'] + 1)
    df['amt_vs_avg'] = df['transaction_amount_inr'] / (df['avg_txn_amount_30d'] + 1)
    df['is_night'] = df['transaction_hour'].apply(lambda x: 1 if x <= 4 or x >= 23 else 0)
    
    # Drop non-predictive columns
    drop_cols = ['transaction_id', 'cardholder_id', 'merchant_id', 'transaction_timestamp']
    return df.drop(columns=[c for c in drop_cols if c in df.columns])

train_fe = engineer_features(train_df)
test_fe = engineer_features(test_df)

# Categorical Encoding
cat_cols = ['merchant_category', 'country_code', 'pos_entry_mode']
for col in cat_cols:
    le = LabelEncoder()
    combined = pd.concat([train_fe[col], test_fe[col]]).astype(str)
    le.fit(combined)
    train_fe[col] = le.transform(train_fe[col].astype(str))
    test_fe[col] = le.transform(test_fe[col].astype(str))

X = train_fe.drop('is_fraud', axis=1)
y = train_fe['is_fraud']
X_train, X_val, y_train, y_val = train_test_split(X, y, test_size=0.2, stratify=y, random_state=42)
print("✅ Data Loaded and Preprocessed")




  # We use a fixed weight of 15. This is strong enough to find fraud 
# but low enough to keep probabilities from jumping to 1.0 immediately.
model = xgb.XGBClassifier(
    n_estimators=300,
    max_depth=4,
    learning_rate=0.05,
    scale_pos_weight=15, 
    eval_metric='logloss',
    random_state=42
)

model.fit(X_train, y_train)
print("✅ XGBoost Trained.")




  y_probs = model.predict_proba(X_val)[:, 1]

# Instead of searching for 75% recall (which is failing), 
# let's flag the top 8% of transactions as suspicious.
# This almost always hits the >75% recall target in fraud data.
final_threshold = np.percentile(y_probs, 92) # 92nd percentile = top 8% flagged

# Ensure the threshold is below 0.5 as requested
if final_threshold >= 0.5:
    final_threshold = 0.35

y_pred = (y_probs >= final_threshold).astype(int)

print(f"📊 Final Threshold: {final_threshold:.4f}")
print(f"📊 Flagged as Fraud: {sum(y_pred)} out of {len(y_pred)}")
print("-" * 30)
print(classification_report(y_val, y_pred))




  test_probs = model.predict_proba(test_fe)[:, 1]
test_preds = (test_probs >= final_threshold).astype(int)

submission = pd.DataFrame({
    'transaction_id': test_df['transaction_id'],
    'is_fraud': test_preds
})

print("Final Counts in CSV:")
print(submission['is_fraud'].value_counts())

submission.to_csv('final_fraud_predictions.csv', index=False)
print("\n✅ Success! File generated with a stable class mix.")
